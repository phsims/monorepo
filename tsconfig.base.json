{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@monorepo/source"],
    "baseUrl": ".",
    "paths": {
      "themes/*": ["themes/*"],
      "components/react/atoms/*": ["libs/components/react/atoms/src/lib/*"],
      "components/react/molecules/*": [
        "libs/components/react/molecules/src/lib/*"
      ],
      "components/react/organisms/*": [
        "libs/components/react/organisms/src/lib/*"
      ]
    }
  }
}
