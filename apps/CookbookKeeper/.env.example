# Spoonacular (recipes)
SPOONACULAR_API_KEY=

# Contact form — Cloudflare Turnstile (https://developers.cloudflare.com/turnstile/)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# GitHub issue creation (fine-grained PAT: Issues write on target repo, or classic PAT with `repo` scope)
GITHUB_CONTACT_TOKEN=

# Optional: override repository for contact tickets (defaults: phsims / monorepo)
# CONTACT_GITHUB_OWNER=phsims
# CONTACT_GITHUB_REPO=monorepo

# Optional: comma-separated label names (must already exist on the repo)
# CONTACT_GITHUB_LABELS=contact-form
